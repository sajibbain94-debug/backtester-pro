# ─────────────────────────────────────────────────────────────────────────────
# BacktesterPro — Environment Variables
# Copy this file to .env.local and fill in your API keys.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Finnhub API key (free tier: 60 calls/min)
# Get yours at https://finnhub.io/
VITE_FINNHUB_API_KEY=your_finnhub_key_here

# Alpha Vantage API key (free tier: 25 calls/day)
# Get yours at https://www.alphavantage.co/support/#api-key
VITE_ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Feature flags
VITE_ENABLE_REAL_DATA=true
VITE_CACHE_TTL_MINUTES=60
